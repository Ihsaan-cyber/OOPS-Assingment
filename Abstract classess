#include <iostream>
#include <string>
#include <vector>
#include <memory>
#include <cmath>
using namespace std;


// EXAMPLE 1 – Shape hierarchy (pure interface style)

class Shape {                       
protected:
    string color;
public:
    Shape(const string& c = "black") : color(c) {}

    
    virtual double area()      const = 0;
    virtual double perimeter() const = 0;
    virtual string name()      const = 0;

    
    void printInfo() const {
        cout << "  " << name()
             << " [" << color << "]"
             << "  area="      << area()
             << "  perimeter=" << perimeter() << "\n";
    }

    virtual ~Shape() = default;
};

class Circle : public Shape {
    double r;
public:
    Circle(double radius, const string& c = "red")
        : Shape(c), r(radius) {}
    double area()      const override { return M_PI * r * r; }
    double perimeter() const override { return 2 * M_PI * r; }
    string name()      const override { return "Circle   "; }
};

class Rectangle : public Shape {
    double w, h;
public:
    Rectangle(double width, double height, const string& c = "blue")
        : Shape(c), w(width), h(height) {}
    double area()      const override { return w * h; }
    double perimeter() const override { return 2*(w+h); }
    string name()      const override { return "Rectangle"; }
};

class EquilateralTriangle : public Shape {
    double side;
public:
    EquilateralTriangle(double s, const string& c = "green")
        : Shape(c), side(s) {}
    double area()      const override { return (sqrt(3.0)/4.0) * side * side; }
    double perimeter() const override { return 3 * side; }
    string name()      const override { return "EqTriangle"; }
};


// EXAMPLE 2 – Template Method Pattern

class DataProcessor {               
public:
    
    void process() {
        readData();
        processData();
        writeOutput();
    }

protected:
    virtual void readData()    = 0;
    virtual void processData() = 0;
    virtual void writeOutput() = 0;

    virtual ~DataProcessor() = default;
};

class CSVProcessor : public DataProcessor {
protected:
    void readData()    override { cout << "  [CSV]  Reading  CSV file\n"; }
    void processData() override { cout << "  [CSV]  Parsing  rows and columns\n"; }
    void writeOutput() override { cout << "  [CSV]  Writing  results to output.csv\n"; }
};

class JSONProcessor : public DataProcessor {
protected:
    void readData()    override { cout << "  [JSON] Reading  JSON file\n"; }
    void processData() override { cout << "  [JSON] Parsing  JSON tree\n"; }
    void writeOutput() override { cout << "  [JSON] Writing  results to output.json\n"; }
};


// EXAMPLE 3 – Abstract class with constructor & concrete members

class BankAccount {                 
protected:
    string owner;
    double balance;

public:
    BankAccount(const string& o, double b) : owner(o), balance(b) {
        cout << "  [BankAccount] Account created for " << owner << "\n";
    }

    // Pure virtual – deposit/withdraw rules differ per account type
    virtual void deposit(double amount)  = 0;
    virtual void withdraw(double amount) = 0;

    
    double getBalance() const { return balance; }
    void   showBalance() const {
        cout << "  " << owner << "'s balance: " << balance << "\n";
    }

    virtual ~BankAccount() = default;
};

class SavingsAccount : public BankAccount {
    double interestRate;
public:
    SavingsAccount(const string& o, double b, double rate)
        : BankAccount(o, b), interestRate(rate) {}

    void deposit(double amount) override {
        balance += amount * (1 + interestRate);  
        cout << "  [Savings] Deposited " << amount
             << " (with interest). New balance: " << balance << "\n";
    }

    void withdraw(double amount) override {
        if (amount > balance)
            cout << "  [Savings] Insufficient funds!\n";
        else {
            balance -= amount;
            cout << "  [Savings] Withdrew " << amount
                 << ". New balance: " << balance << "\n";
        }
    }
};

class CurrentAccount : public BankAccount {
    double overdraftLimit;
public:
    CurrentAccount(const string& o, double b, double limit)
        : BankAccount(o, b), overdraftLimit(limit) {}

    void deposit(double amount) override {
        balance += amount;
        cout << "  [Current] Deposited " << amount
             << ". New balance: " << balance << "\n";
    }

    void withdraw(double amount) override {
        if (amount > balance + overdraftLimit)
            cout << "  [Current] Exceeds overdraft limit!\n";
        else {
            balance -= amount;
            cout << "  [Current] Withdrew " << amount
                 << ". New balance: " << balance << "\n";
        }
    }
};

// ---------- main ----------
int main() {
    cout << "===== Abstract Classes Demo =====\n\n";

    // -- EXAMPLE 1 --
    cout << "--- 1. Shape hierarchy ---\n";
    // Shape s;  // ERROR: cannot instantiate abstract class
    vector<unique_ptr<Shape>> shapes;
    shapes.push_back(make_unique<Circle>(5.0));
    shapes.push_back(make_unique<Rectangle>(4.0, 6.0));
    shapes.push_back(make_unique<EquilateralTriangle>(7.0));
    for (const auto& s : shapes) s->printInfo();

    // -- EXAMPLE 2 --
    cout << "\n--- 2. Template Method Pattern ---\n";
    vector<unique_ptr<DataProcessor>> procs;
    procs.push_back(make_unique<CSVProcessor>());
    procs.push_back(make_unique<JSONProcessor>());
    for (auto& p : procs) { p->process(); cout << "\n"; }

    // -- EXAMPLE 3 --
    cout << "--- 3. Abstract BankAccount ---\n";
    vector<unique_ptr<BankAccount>> accounts;
    accounts.push_back(make_unique<SavingsAccount>("Alice", 1000.0, 0.05));
    accounts.push_back(make_unique<CurrentAccount>("Bob",   500.0, 200.0));

    accounts[0]->deposit(200);
    accounts[0]->withdraw(50);
    accounts[1]->deposit(300);
    accounts[1]->withdraw(900);   
    accounts[1]->withdraw(500);   

    return 0;
}
